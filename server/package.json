  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "concurrently": "^7.0.0",
    "dotenv": "^15.0.0",
    "mongoose-tsgen": "^8.4.8",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.4.3"
  }
}
